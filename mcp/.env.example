# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# Used by examples/enzyme_kinetics_agent.py and to configure the MCP server.

# --- BRENDA database (required) ---
# Path to the BRENDA JSON file. Accepts .json, .json.gz, or .json.tar.gz.
# Due to BRENDA's license you must download it yourself from
# https://www.brenda-enzymes.org/download.php
BRENDA_DATABASE_PATH=/absolute/path/to/brenda_2026_1.json

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# --- DeepSeek (OpenAI-compatible API) ---
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
